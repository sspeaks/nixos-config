#!/usr/bin/env bash
# Format staged .nix files before commit
# Install: git config core.hooksPath .githooks

if ! command -v treefmt &>/dev/null; then
  echo "treefmt not found — run 'nix develop' or 'nix fmt' manually" >&2
  exit 1
fi

# Get staged .nix files
STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.nix')
if [ -z "$STAGED" ]; then
  exit 0
fi

# Format and re-stage
echo "$STAGED" | xargs treefmt --quiet
echo "$STAGED" | xargs git add
